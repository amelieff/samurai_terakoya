        "import random\n",
        "\n",
        "var = random.randint(1,100)\n",
        "\n",
        "# var の値を確認\n",
        "print(\"変数var の値\")\n",
        "print(var)\n",
        "\n",
        "print(\"出力\")\n",
        "\n",
        "if var % 3 == 0 and var % 5 == 0:\n",
        "    print(\"FizzBuzz\")\n",
        "elif var % 3 == 0:\n",
        "    print(\"Fizz\")\n",
        "elif var % 5 == 0:\n",
        "    print(\"Buzz\")\n",
        "else:\n",
        "    print(var)"
