        "import random\n",
        "var = random.randint(1,20)\n",
        "print(var)\n",
        "\n",
        "if (var % 3 ) == 0 and (var % 5 ) == 0:\n",
        "  print(\"FizzBuzz\")\n",
        "elif(var % 3 ) == 0:\n",
        "  print(\"Fizz\")\n",
        "elif(var % 5 ) == 0:\n",
        "  print(\"Buzz\")\n",
        "else:\n",
        "  print(var)\n"
      ]
