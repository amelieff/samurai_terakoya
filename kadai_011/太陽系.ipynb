      "source": [
        "array = [\"水\",\"金\",\"地\",\"火\",\"木\",\"土\",\"天\",\"海\",\"冥\"]"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# forでのループ\n",
        "repeat_array = array * 2\n",
        "for value in repeat_array:\n",
        "  print(value)"
