      "cell_type": "code",
      "source": [
        "# whileでのループ\n",
        "list_length = len(array)\n",
        "count = 0\n",
        "while count < list_length * 2:\n",
        "    print(array[count % list_length])\n",
        "    count += 1"
      ],
