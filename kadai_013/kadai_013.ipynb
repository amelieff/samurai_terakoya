      "source": [
        "def calculate_taxed_price(price, tax_rate):\n",
        "    tax_amount = price * (tax_rate / 100)\n",
        "    price_with_tax = price + tax_amount\n",
        "\n",
        "    return price_with_tax\n",
        "\n",
        "price = 110\n",
        "tax_rate = 10\n",
        "taxed_price = calculate_taxed_price(price, tax_rate)\n",
        "print(taxed_price)\n"
