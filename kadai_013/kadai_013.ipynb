        "def calculate_account(price: int, tax: int) -> int:\n",
        "  total_accunt = price * (1 +  (tax / 100))\n",
        "  return total_accunt\n",
        "\n",
        "price = 110\n",
        "tax = 10\n",
        "\n",
        "print( str(calculate_account(price, tax)) )\n",
