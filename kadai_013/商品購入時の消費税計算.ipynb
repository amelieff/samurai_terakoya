      "source": [
        "def calculate_total_price(price: int, tax_rate: int) -> int:\n",
        "    tax_amount = price * (tax_rate / 100)\n",
        "    total_price = price + tax_amount\n",
        "    return total_price"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "calculate_total_price(110, 10)"
