        "def calc(item, tax):\n",
        "\n",
        "  tax_amount = item * (tax / 100)\n",
        "  total_price = item + tax_amount\n",
        "  return total_price\n",
        "\n",
        "item = 110\n",
        "tax = 10\n",
        "\n",
        "final_price = calc(item, tax)\n",
        "print(final_price)"
