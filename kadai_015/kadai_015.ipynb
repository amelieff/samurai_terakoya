        "class Human:\n",
        "  def __init__(self, name, age):\n",
        "    self.name = name\n",
        "    self.age = age\n",
        "\n",
        "  def printinfo(self):\n",
        "    print(self.name)\n",
        "    print(self.age)\n",
        "\n",
        "user = Human(\"太郎\", 30)\n",
        "user.printinfo()\n",
        "\n",
        "\n"
      ],
