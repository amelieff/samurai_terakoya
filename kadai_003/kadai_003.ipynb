      "source": [
        "import numpy as np\n",
        "\n",
        "A = np.array([[1, 2, 3],\n",
        "              [4, 5, 6]])\n",
        "\n",
        "B = np.array([[7, 8],\n",
        "              [9, 10],\n",
        "              [11, 12]])\n",
        "\n",
        "C = np.dot(A, B)\n",
        "\n",
        "print(\"行列の積:\\n\", C)\n",
        "\n",
        "max_value = np.max(C)\n",
        "print(\"行列の最大値:\", max_value)"
      ]
